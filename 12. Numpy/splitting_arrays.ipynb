    "\n",
    "# part1,part2,part3=np.split(arr,3)\n",
    "\n",
    "part1,part2,part3=np.split(arr,[5,7])\n",
    "print(part1)\n",
    "print(part2)\n",
    "print(part3)\n"
   ]
