   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "sales = pd.read_csv(\"monthly_sales.csv\")\n",
    "sales[\"date\"] = pd.to_datetime(sales[\"date\"])\n",
    "\n",
    "pivoted = sales.pivot_table(index=\"product\", columns=\"region\",\n",
    "                            values=\"revenue\", aggfunc=\"sum\")\n",
    "\n",
    "r=pivoted.stack()\n",
    "r.unstack()"
   ]
  }
