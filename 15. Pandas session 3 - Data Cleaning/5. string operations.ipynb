   "source": [
    "import pandas as pd\n",
    "\n",
    "df = pd.read_csv(\"employees.csv\")\n",
    "\n",
    "df[\"City\"]=df[\"City\"].str.strip()\n",
    "df[\"name\"]=df[\"name\"].str.title()\n",
    "\n",
    "df[\"first_name\"] = df[\"name\"].str.split().str[0]\n",
    "df[\"last_name\"] = df[\"name\"].str.split().str[1]\n",
    "df[\"username\"] = df[\"email\"].str.split(\"@\").str[0]\n",
    "df"
   ]
  }
